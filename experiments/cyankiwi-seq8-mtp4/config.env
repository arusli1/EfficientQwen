# cyankiwi-seq8-mtp4 — latency-optimized variant. Same AWQ-4bit weights as
# cyankiwi-seq8, with three runtime tunings stacked on top:
#   1. MTP K=4          — sweep-optimal speculative depth (see results/mtp_k_sweep.json)
#   2. matched cudagraph capture sizes for K=4 x max_num_seqs in {1..8}
#   3. repetition_penalty=1.0 — keeps speculative acceptance high on long outputs
# Local benchmarks: ~+8% average decode latency vs the K=7 cyankiwi-seq8 config.
VLLM_MODEL=weights/cyankiwi
VLLM_PORT=8080
VLLM_INTERNAL_PORT=8181
VLLM_DTYPE=float16
VLLM_BLOCK_SIZE=16
VLLM_LANGUAGE_MODEL_ONLY=1
VLLM_MAX_NUM_SEQS=8
VLLM_MAX_MODEL_LEN=13312
VLLM_MAX_NUM_BATCHED_TOKENS=1024
VLLM_ENABLE_CHUNKED_PREFILL=1
VLLM_ENABLE_PREFIX_CACHING=1
VLLM_GPU_MEMORY_UTILIZATION=0.92
VLLM_ENFORCE_EAGER=0
VLLM_SPECULATIVE_CONFIG='{"method":"mtp","num_speculative_tokens":4}'
VLLM_CUDAGRAPH_CAPTURE_SIZES=5,10,15,20,25,30,35,40
VLLM_REPETITION_PENALTY=1.0
