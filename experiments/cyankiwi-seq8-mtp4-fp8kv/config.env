# cyankiwi-seq8-mtp4-fp8kv — memory-optimized variant. Identical to
# cyankiwi-seq8-mtp4 plus an FP8 (E4M3) KV cache, which roughly halves KV-cache
# memory and frees headroom for longer contexts / larger batches on a 24 GB A10G.
# Quality-neutral in principle (KV quantization only affects attention reads),
# but not separately benchmarked here — provided as a ready-to-serve config.
VLLM_MODEL=weights/cyankiwi
VLLM_PORT=8080
VLLM_INTERNAL_PORT=8181
VLLM_DTYPE=float16
VLLM_BLOCK_SIZE=16
VLLM_LANGUAGE_MODEL_ONLY=1
VLLM_MAX_NUM_SEQS=8
VLLM_MAX_MODEL_LEN=13312
VLLM_MAX_NUM_BATCHED_TOKENS=1024
VLLM_ENABLE_CHUNKED_PREFILL=1
VLLM_ENABLE_PREFIX_CACHING=1
VLLM_GPU_MEMORY_UTILIZATION=0.92
VLLM_ENFORCE_EAGER=0
VLLM_SPECULATIVE_CONFIG='{"method":"mtp","num_speculative_tokens":4}'
VLLM_CUDAGRAPH_CAPTURE_SIZES=5,10,15,20,25,30,35,40
VLLM_REPETITION_PENALTY=1.0
VLLM_KV_CACHE_DTYPE=fp8
