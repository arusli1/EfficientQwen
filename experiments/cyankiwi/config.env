# cyankiwi — AWQ-4bit reference (Qwen3.5-4B, compressed-tensors W4A16 MLPs).
# Single-stream serving with MTP K=7 speculative decoding. This is the quality
# reference every other variant is measured against.
#
# max_model_len = 13312 = 12288 (thinking-mode generation budget) + 1024 prompt.
VLLM_MODEL=weights/cyankiwi
VLLM_PORT=8080
VLLM_INTERNAL_PORT=8181
VLLM_DTYPE=float16
VLLM_BLOCK_SIZE=16
VLLM_LANGUAGE_MODEL_ONLY=1
VLLM_MAX_NUM_SEQS=1
VLLM_MAX_MODEL_LEN=13312
VLLM_MAX_NUM_BATCHED_TOKENS=1024
VLLM_ENABLE_CHUNKED_PREFILL=1
VLLM_ENABLE_PREFIX_CACHING=1
VLLM_GPU_MEMORY_UTILIZATION=0.90
VLLM_ENFORCE_EAGER=0
VLLM_SPECULATIVE_CONFIG='{"method":"mtp","num_speculative_tokens":7}'
# At max_num_seqs=1 + MTP=7 the runtime only executes batch shape 8
# (1 prompt token + 7 MTP candidates), so a single CUDA graph size is captured.
VLLM_CUDAGRAPH_CAPTURE_SIZES=8
