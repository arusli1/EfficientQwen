# cyankiwi-seq8 — throughput-tuned reference. Same AWQ-4bit weights as cyankiwi,
# raised to max_num_seqs=8 so batched evals (MMLU-Pro, GPQA-D) finish inside the
# per-task wall-clock budget. MTP K=7. This is the configuration measured at
# ~3.4x over the BF16 baseline.
VLLM_MODEL=weights/cyankiwi
VLLM_PORT=8080
VLLM_INTERNAL_PORT=8181
VLLM_DTYPE=float16
VLLM_BLOCK_SIZE=16
VLLM_LANGUAGE_MODEL_ONLY=1
VLLM_MAX_NUM_SEQS=8
VLLM_MAX_MODEL_LEN=13312
VLLM_MAX_NUM_BATCHED_TOKENS=1024
VLLM_ENABLE_CHUNKED_PREFILL=1
VLLM_ENABLE_PREFIX_CACHING=1
VLLM_GPU_MEMORY_UTILIZATION=0.92
VLLM_ENFORCE_EAGER=0
VLLM_SPECULATIVE_CONFIG='{"method":"mtp","num_speculative_tokens":7}'
# Every batch shape MTP=7 x max_num_seqs in {1..8} can produce:
# (1 prompt token + 7 MTP candidates) x {1..8} = {8,16,24,32,40,48,56,64}.
VLLM_CUDAGRAPH_CAPTURE_SIZES=8,16,24,32,40,48,56,64
